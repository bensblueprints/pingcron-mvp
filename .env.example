# Pingcron configuration — copy to .env and edit

# Port the web app listens on
PORT=5320

# Admin password for the dashboard (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location
DB_PATH=./data/pingcron.db

# Public base URL of this install — used for links inside alerts
# e.g. https://ping.yourdomain.com
BASE_URL=

# SMTP for email alerts (optional — webhook alerts work without SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Evaluator loop interval in ms (default 15000). Lower = faster detection.
EVAL_INTERVAL_MS=15000
